# ── Database ────────────────────────────────────────────
# Get from Supabase: Project > Settings > Database > Connection String (URI mode)
# For local Docker dev: postgresql://postgres:postgres@localhost:5432/smartcat
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_characters
JWT_EXPIRES_IN=7d

# ── MQTT (HiveMQ Cloud free tier) ─────────────────────────
# For local Docker dev: use localhost and port 1883
MQTT_BROKER_HOST=your-cluster-id.s1.eu.hivemq.cloud
MQTT_BROKER_PORT=8883
MQTT_USERNAME=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password
MQTT_CLIENT_ID=smartcat-backend

# ── Telegram Bot ──────────────────────────────────────────
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Comma-separated Telegram chat IDs allowed to control the feeder
# Get your chat ID by sending a message to @userinfobot
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# ── Safety limits ─────────────────────────────────────────
FEED_COOLDOWN_SECONDS=60
MAX_FEEDS_PER_DAY=10

# ── Server ────────────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
